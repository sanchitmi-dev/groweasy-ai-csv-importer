{
  "name": "groweasy-ai-csv-importer",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered CSV importer for mapping arbitrary lead exports into GrowEasy CRM format.",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "next dev -p 3000",
    "dev:api": "tsx watch server/index.ts",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "ai": "^4.3.19",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "express": "^4.19.2",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "multer": "^1.4.5-lts.1",
    "next": "^14.2.30",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.30",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
