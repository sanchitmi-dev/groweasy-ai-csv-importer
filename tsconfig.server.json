{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "noEmit": false,
    "jsx": "react-jsx",
    "types": ["node"],
    "incremental": false
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", ".next", "app", "components", "server/**/*.test.ts"]
}
